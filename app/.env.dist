# Domyślne zmienne środowiskowe dla lokalnego uruchomienia aplikacji.
# Skopiuj ten plik do app/.env i uzupełnij wartości zależne od środowiska.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://symfony:symfony@db:5432/cepik?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> app/custom ###
CEPIK_API_BASE_URI=https://api.cepik.gov.pl
CEPIK_API_TIMEOUT=120
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URI=https://api.openai.com/v1
###< app/custom ###
